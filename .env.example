# =============================================================================
# Nexus E-Commerce Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# 🔴 = Required   🟡 = Required for specific features   ⚪ = Optional
# =============================================================================

# =============================================================================
# 1. APPLICATION
# =============================================================================

# 🔴 AUTH_SECRET - Used by NextAuth.js to encrypt JWT cookies and tokens.
#    Generate with: openssl rand -base64 32  OR  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# ⚪ AUTH_URL - Canonical URL of your site (used by NextAuth for callbacks).
#    In development: http://localhost:3000
AUTH_URL=http://localhost:3000

# 🔴 NEXT_PUBLIC_BASE_URL - Public-facing base URL for sitemap, robots, and SEO metadata.
#    Must be a full URL without trailing slash.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ⚪ NEXT_PUBLIC_APP_URL - Used in email links (cart, order confirmation, etc.).
#    Falls back to http://localhost:3000 if not set.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ⚪ NODE_ENV - Runtime environment. Usually set automatically by Next.js.
#    Options: development | production | test
NODE_ENV=development

# ⚪ NEXT_PUBLIC_SITE_NAME - Brand name used in email templates and page titles.
#    Defaults to "Nexus" if not set.
NEXT_PUBLIC_SITE_NAME="Nexus"

# ⚪ NEXT_PUBLIC_SITE_URL - Public site URL (alternative/alias for APP_URL).
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# =============================================================================
# 2. AUTHENTICATION (OAuth Providers)
# =============================================================================
# Create credentials at:
#   Google: https://console.cloud.google.com/apis/credentials
#   GitHub: https://github.com/settings/developers

# --- Google OAuth ---
# 🟡 GOOGLE_CLIENT_ID - OAuth 2.0 Client ID from Google Cloud Console.
#    Required if Google sign-in is enabled.
GOOGLE_CLIENT_ID=

# 🟡 GOOGLE_CLIENT_SECRET - OAuth 2.0 Client Secret from Google Cloud Console.
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth ---
# 🟡 GITHUB_CLIENT_ID - OAuth App Client ID from GitHub Developer Settings.
#    Required if GitHub sign-in is enabled.
GITHUB_CLIENT_ID=

# 🟡 GITHUB_CLIENT_SECRET - OAuth App Client Secret from GitHub Developer Settings.
GITHUB_CLIENT_SECRET=

# --- NextAuth v5 OAuth (alternative naming) ---
# ⚪ If you use AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET instead of GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=


# =============================================================================
# 3. DATABASE (MongoDB)
# =============================================================================

# 🔴 MONGODB_URI - MongoDB connection string.
#    Local:    mongodb://localhost:27017/full_stack_e_commerce_next_js
#    Atlas:    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/full_stack_e_commerce_next_js


# =============================================================================
# 4. JWT (Access & Refresh Tokens)
# =============================================================================
# Used for API authentication alongside NextAuth sessions.

# 🔴 ACCESS_TOKEN_SECRET - Secret key for signing access tokens (32+ hex chars).
#    Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=

# 🔴 REFRESH_TOKEN_SECRET - Secret key for signing refresh tokens (32+ hex chars).
REFRESH_TOKEN_SECRET=

# ⚪ ACCESS_TOKEN_EXPIRY - Access token expiration duration (ms | s | m | h | d).
#    Default: 15m
ACCESS_TOKEN_EXPIRY=15m

# ⚪ REFRESH_TOKEN_EXPIRY - Refresh token expiration duration.
#    Default: 7d
REFRESH_TOKEN_EXPIRY=7d


# =============================================================================
# 5. REDIS / UPSTASH
# =============================================================================
# Used for caching, rate limiting, and Socket.io adapter.
# Sign up at: https://upstash.com

# 🟡 UPSTASH_REDIS_REST_URL - Upstash Redis REST API endpoint.
#    Required if using Redis for caching or Socket.io pub/sub.
UPSTASH_REDIS_REST_URL=

# 🟡 UPSTASH_REDIS_REST_TOKEN - Upstash Redis REST API token.
UPSTASH_REDIS_REST_TOKEN=


# =============================================================================
# 6. CLOUDINARY (Media Storage)
# =============================================================================
# Used for image uploads (product images, avatars, etc.).
# Sign up at: https://cloudinary.com

# 🔴 NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME - Your Cloudinary cloud name (public).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# 🔴 CLOUDINARY_API_KEY - Cloudinary API Key.
CLOUDINARY_API_KEY=

# 🔴 CLOUDINARY_API_SECRET - Cloudinary API Secret (keep private).
CLOUDINARY_API_SECRET=


# =============================================================================
# 7. EMAIL / SMTP
# =============================================================================
# Used for transactional emails (verification, password reset, order updates, etc.).

# --- SMTP Configuration ---

# 🟡 SMTP_HOST - SMTP server hostname.
#    Gmail: smtp.gmail.com  |  SendGrid: smtp.sendgrid.net  |  Mailgun: smtp.mailgun.org
SMTP_HOST=smtp.gmail.com

# 🟡 SMTP_PORT - SMTP server port.
#    587 (STARTTLS) | 465 (SSL) | 25 (plain, not recommended)
SMTP_PORT=587

# ⚪ SMTP_SECURE - Whether to use SSL/TLS. true for port 465, false for 587.
SMTP_SECURE=false

# 🟡 SMTP_USER - SMTP authentication username (usually your email address).
SMTP_USER=

# 🟡 SMTP_PASS - SMTP authentication password or app-specific password.
#    For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_PASS=

# 🟡 EMAIL_FROM_NAME - Display name for outgoing emails.
#    Example: "Nexus Support"
EMAIL_FROM_NAME="Nexus Support"

# 🟡 EMAIL_FROM_ADDRESS - "From" email address for outgoing emails.
EMAIL_FROM_ADDRESS=noreply@example.com

# --- Resend (alternative email service) ---

# ⚪ RESEND_API_KEY - API key for Resend.com email service (alternative to SMTP).
#    Sign up at: https://resend.com
RESEND_API_KEY=

# --- Legacy email variables (kept for backward compatibility) ---
# ⚪ These are fallbacks; prefer the SMTP_* / EMAIL_FROM_* variables above.
EMAIL_SERVER=
EMAIL_FROM=
EMAIL_PASSWORD=


# =============================================================================
# 8. SOCKET.IO (Real-time)
# =============================================================================
# Used for real-time notifications, live order updates, and admin dashboard.

# 🟡 NEXT_PUBLIC_SOCKET_URL - Client-facing Socket.io server URL.
#    In development: http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# 🟡 SOCKET_PORT - Port the Socket.io server listens on.
#    Must match the port in NEXT_PUBLIC_SOCKET_URL.
SOCKET_PORT=3001


# =============================================================================
# 9. STRIPE (Payments)
# =============================================================================
# Used for credit/debit card payments.
# Sign up at: https://dashboard.stripe.com

# 🔴 NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY - Stripe publishable key (starts with pk_test_ or pk_live_).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# 🔴 STRIPE_SECRET_KEY - Stripe secret key (starts with sk_test_ or sk_live_). Keep private!
STRIPE_SECRET_KEY=

# 🟡 STRIPE_WEBHOOK_SECRET - Stripe webhook signing secret (starts with whsec_).
#    Required for handling Stripe webhook events (payment confirmations, refunds, etc.).
#    Get this from Stripe Dashboard > Webhooks > Your endpoint > Signing secret.
STRIPE_WEBHOOK_SECRET=


# =============================================================================
# 10. PAYPAL (Payments)
# =============================================================================
# Used for PayPal payment method.
# Sign up at: https://developer.paypal.com

# 🟡 NEXT_PUBLIC_PAYPAL_CLIENT_ID - PayPal client ID (public, used on the frontend).
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# 🟡 PAYPAL_CLIENT_ID - PayPal client ID (server-side, used in API routes).
PAYPAL_CLIENT_ID=

# 🟡 PAYPAL_CLIENT_SECRET - PayPal client secret (server-side). Keep private!
PAYPAL_CLIENT_SECRET=


# =============================================================================
# 11. ANALYTICS & SEO
# =============================================================================

# ⚪ NEXT_PUBLIC_GA_ID - Google Analytics 4 Measurement ID.
#    Format: G-XXXXXXXXXX
#    Sign up at: https://analytics.google.com
NEXT_PUBLIC_GA_ID=

# ⚪ NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION - Google Search Console verification string.
#    Used in the site meta tag for domain ownership verification.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=


# =============================================================================
# 12. BUNDLE ANALYZER
# =============================================================================

# ⚪ ANALYZE - Set to "true" to run the Next.js Bundle Analyzer.
#    Generates a visual report of JS bundle sizes.
#    Run: ANALYZE=true npm run build
ANALYZE=false


# =============================================================================
# 13. SENTRY (Error Tracking)
# =============================================================================
# Used for monitoring and tracking production errors.
# Sign up at: https://sentry.io

# ⚪ SENTRY_DSN - Sentry Data Source Name (DSN) for error reporting.
#    Format: https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_DSN=


# =============================================================================
# 14. LOGGING
# =============================================================================

# ⚪ LOG_LEVEL - Application logging verbosity.
#    Options: error | warn | info | debug | trace
#    Default: info in production, debug in development
LOG_LEVEL=debug
